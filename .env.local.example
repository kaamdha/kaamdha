# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gupshup (SMS/WhatsApp)
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_APP_NAME=kaamdha
GUPSHUP_WHATSAPP_NUMBER=your-whatsapp-business-number

# Mappls / MapMyIndia (fallback geocoding)
MAPPLS_CLIENT_ID=your-mappls-client-id
MAPPLS_CLIENT_SECRET=your-mappls-client-secret

# Supabase Admin (server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron
CRON_SECRET=your-cron-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
